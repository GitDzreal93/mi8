# Application Settings
APP_NAME=mil-intel-api
ENVIRONMENT=local
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://admin:Postgres%402026@localhost:5432/mi8

# DeepSeek LLM Settings
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=512
DEEPSEEK_RATE_LIMIT_QPS=0.5
DEEPSEEK_DAILY_TOKEN_CAP=200000
DEEPSEEK_DAILY_REQUEST_CAP=5000
DEEPSEEK_TIMEOUT_SECONDS=30

# Data Source API Keys
GNEWS_API_KEY=your_gnews_api_key_here
NEWSAPI_API_KEY=your_newsapi_api_key_here
ACLED_API_KEY=your_acled_api_key_here

# RSSHub Settings
RSSHUB_BASE=https://rsshub.app

# NASA FIRMS API (Optional)
FIRMS_API=https://firms.modaps.eosdis.nasa.gov/api/

# ADS-B Exchange (Optional)
ADSB_ENABLED=false

# Daily API Limits
GNEWS_DAILY_LIMIT=100
NEWSAPI_DAILY_LIMIT=100
ACLED_DAILY_LIMIT=1000
RSSHUB_DAILY_LIMIT=1000
FIRMS_DAILY_LIMIT=200

# Polling Settings
POLL_INTERVAL_MINUTES=30
QUOTA_STOP_RATIO=0.8

# JWT Authentication
JWT_SECRET=change_this_to_a_secure_random_string
JWT_ALGORITHM=HS256

# Alert Settings (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_FROM=alerts@milintel.local
ALERT_TO=admin@example.com,ops@example.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Alert Thresholds
ALERT_MIN_IMPORTANCE=4
ALERT_QUOTA_THRESHOLD=0.8
